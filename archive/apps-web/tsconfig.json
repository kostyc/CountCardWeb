{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/lib/permissions/types": ["../../packages/core/src/permissions/types.ts"],
      "@/lib/permissions/roles": ["../../packages/core/src/permissions/roles.ts"],
      "@/lib/permissions/utils": ["../../packages/core/src/permissions/utils.ts"],
      "@/lib/permissions/recruits": ["../../packages/core/src/permissions/recruits.ts"],
      "@/*": ["./*"],
      "@/types/*": ["../../packages/core/src/types/*"],
      "@/lib/validation": ["../../packages/core/src/validation/index.ts"],
      "@/lib/validation/*": ["../../packages/core/src/validation/*"],
      "@/lib/constants/*": ["../../packages/core/src/constants/*"],
      "@/lib/services/firestore": ["../../packages/firebase/src/services/index.ts"],
      "@/lib/services/firestore/*": ["../../packages/firebase/src/services/*"],
      "@/lib/encryption": ["../../packages/encryption/src/index.ts"],
      "@/lib/encryption/*": ["../../packages/encryption/src/*"],
      "@/lib/design/tokens": ["../../packages/ui/src/tokens.ts"],
      "@countcard/ui": ["../../packages/ui/src/index.ts"],
      "@countcard/ui/*": ["../../packages/ui/src/*"],
      "@/lib/api/clientAuth": ["../../packages/api-client/src/index.ts"],
      "@/hooks/useConversations": ["../../packages/firebase/src/hooks/useConversations.ts"],
      "@/hooks/useMessages": ["../../packages/firebase/src/hooks/useMessages.ts"],
      "@countcard/core": ["../../packages/core/src/index.ts"],
      "@countcard/core/*": ["../../packages/core/src/*"],
      "@countcard/firebase": ["../../packages/firebase/src/index.ts"],
      "@countcard/firebase/*": ["../../packages/firebase/src/*"],
      "@countcard/encryption": ["../../packages/encryption/src/index.ts"],
      "@countcard/encryption/*": ["../../packages/encryption/src/*"],
      "@countcard/api-client": ["../../packages/api-client/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
  "exclude": ["node_modules"]
}
