rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic restrictive rules - will be expanded in Sprint 14
    // For now, only authenticated users can read/write their own data
    // All access is restricted until proper role-based rules are implemented
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // User Profiles: Users can read/write their own profile
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Conversations: only participants can read/write
    match /conversations/{conversationId} {
      allow read, update, delete: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;
    }
    // Conversation messages: only participants of the parent conversation
    match /conversations/{conversationId}/messages/{messageId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    // Organizational structure: authenticated users (manage_organizations enforced in API; full role-scope in Sprint 14)
    match /regiments/{regimentId} {
      allow read, write: if isAuthenticated();
    }
    match /battalions/{battalionId} {
      allow read, write: if isAuthenticated();
    }
    match /companies/{companyId} {
      allow read, write: if isAuthenticated();
    }
    match /series/{seriesId} {
      allow read, write: if isAuthenticated();
    }
    match /platoons/{platoonId} {
      allow read, write: if isAuthenticated();
    }

    // Report schedules: users can only read/write their own schedules
    match /reportSchedules/{scheduleId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Default deny all access for other collections
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Note: Security rules will be fully implemented in Sprint 14
    // This is a minimal implementation to allow basic app functionality
    // Proper role-based access control will be added in Sprint 14
  }
}
