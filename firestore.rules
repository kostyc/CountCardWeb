rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Minimal rules — full role-scope enforcement in Sprint 14.
    // Workaround (Sprint 26): client SDK + app-layer permissions while Cloud Run API is blocked.

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function callerProfile() {
      return isAuthenticated()
        ? get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data
        : null;
    }

    function callerRole() {
      return request.auth.token.role != null
        ? request.auth.token.role
        : (callerProfile() != null && 'role' in callerProfile() ? callerProfile().role : null);
    }

    function canAssignRoles() {
      return callerRole() in ['company_commander', 'battalion_commander'];
    }

    // User Profiles: owner CRUD; role assigners can read/update any profile
    match /userProfiles/{userId} {
      allow read: if isOwner(userId) || canAssignRoles();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || canAssignRoles();
      allow delete: if isOwner(userId);
    }

    // Recruits & count cards: authenticated access (permissions enforced in app until Sprint 14)
    match /recruits/{recruitId} {
      allow read, write: if isAuthenticated();

      match /progressEvents/{eventId} {
        allow read, write: if isAuthenticated();
      }
      match /comments/{commentId} {
        allow read, write: if isAuthenticated();
      }
      match /weightEntries/{entryId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /transferBatches/{batchId} {
      allow read, write: if isAuthenticated();
    }

    match /diLeadershipCards/{cardId} {
      allow read, write: if isAuthenticated();
    }

    match /countCards/{countCardId} {
      allow read, write: if isAuthenticated();
    }

    match /mcrdCountCards/{countCardId} {
      allow read, write: if isAuthenticated();
    }

    match /companyTrainingDays/{companyKey} {
      allow read, write: if isAuthenticated();
    }

    // Conversations: only participants can read/write
    match /conversations/{conversationId} {
      allow read, update, delete: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    // Organizational structure
    match /regiments/{regimentId} {
      allow read, write: if isAuthenticated();
    }
    match /battalions/{battalionId} {
      allow read, write: if isAuthenticated();
    }
    match /companies/{companyId} {
      allow read, write: if isAuthenticated();
    }
    match /series/{seriesId} {
      allow read, write: if isAuthenticated();
    }
    match /platoons/{platoonId} {
      allow read, write: if isAuthenticated();
    }

    match /reportSchedules/{scheduleId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Immutable audit trail — authenticated users may create entries for their own actions.
    match /adminLogs/{logId} {
      allow create: if isAuthenticated()
        && request.resource.data.logId == logId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
      allow read: if isAuthenticated();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
