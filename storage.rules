rules_version = '2';
// Firebase Storage security rules.
// Deploy: firebase deploy --only storage
// Validates content-type and size server-side to block spoofed or oversized uploads.
service firebase.storage {
  match /b/{bucket}/o {
    // Profile pictures: user can read/write only their own folder; images only, max 5MB
    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }
    // Recruit photos: authenticated users; images only, max 5MB
    match /recruit-photos/{recruitId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }
    // DI leadership 3x5 card imports: uploader owns folder; authenticated read; images only, max 5MB
    match /di-leadership-cards/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }
    // Company and battalion logos: authenticated users; images only, max 2MB
    match /logos/company/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }
    match /logos/battalion/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }
    // Conversation attachments: authenticated users only; app enforces participant check
    // Allowed: images (JPEG, PNG, WebP) and PDF; max 10MB
    match /conversations/{conversationId}/{messageId}/{attachmentId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/(jpeg|jpg|png|webp)')
            || request.resource.contentType == 'application/pdf');
    }
  }
}
